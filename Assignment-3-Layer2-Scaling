import tkinter as tk

def show_comparison():
    text.set(
        "Layer 1 (Ethereum):\n"
        "Gas Fee: HIGH\nSpeed: SLOW\n\n"
        "Layer 2 (Arbitrum Sepolia):\n"
        "Gas Fee: LOW\nSpeed: FAST"
    )

root = tk.Tk()
root.title("Assignment 3 - Layer 2 Scaling")

tk.Label(root, text="Layer 2 vs Layer 1", font=("Arial", 14)).pack(pady=10)

tk.Button(root, text="Show Comparison", command=show_comparison).pack(pady=10)

text = tk.StringVar()
tk.Label(root, textvariable=text, justify="left").pack(pady=20)

root.mainloop()